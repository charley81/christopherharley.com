---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 - Page Not Found | Christopher Harley">
  <section
    class="max-w-max-width mx-auto px-edge-padding py-section-v-space flex flex-col items-center justify-center text-center min-h-[512px]"
  >
    <h1 class="font-display-lg text-display-lg text-text-primary mb-unit">
      404
    </h1>
    <p class="font-body-lg text-body-lg text-text-secondary max-w-md mb-12">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center justify-center py-4 px-8 bg-surface-container-high text-text-primary hover:bg-surface-dim transition-colors duration-300 font-label-mono text-label-mono uppercase tracking-widest"
    >
      Back to Home
    </a>
  </section>
</Layout>
