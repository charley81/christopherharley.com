---
export const prerender = true

import Layout from '../layouts/Layout.astro'
import { ContactForm } from '../components/contact-form'
---

<Layout
  title="Contact - Christopher Harley"
  description="Get in touch with Christopher Harley"
>
  <section
    class="max-w-max-width mx-auto px-edge-padding py-section-v-space flex flex-col items-center justify-center min-h-128"
  >
    <div class="w-full max-w-150">
      <header class="text-center md:text-left mb-20">
        <h1 class="font-headline-lg text-headline-lg text-text-primary mb-6">
          Get in touch
        </h1>
        <p class="font-body-lg text-body-lg text-text-secondary max-w-md">
          For website design/development inquiries, or just to say hi.
        </p>
      </header>

      <!-- Hidden form for Netlify form detection (required for JS-rendered forms) -->
      <form
        name="contact"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        hidden
      >
        <input name="name" />
        <input name="email" />
        <input name="inquiry" />
        <textarea name="message"></textarea>
        <input name="bot-field" />
      </form>

      <ContactForm client:load />

      <div
        class="pt-8 border-t border-border-muted flex flex-col md:flex-row justify-between items-center gap-4 text-text-secondary font-label-mono text-label-mono mt-20"
      >
        <a
          href="mailto:hello@christopherharley.com"
          class="hover:text-text-primary transition-colors duration-200"
        >
          hello@christopherharley.com
        </a>
        <a
          href="#"
          class="hover:text-text-primary transition-colors duration-200 flex items-center gap-1"
        >
          GitHub
          <span class="material-symbols-outlined text-caption">call_made</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
