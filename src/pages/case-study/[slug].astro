---
export const prerender = true

import { Image } from 'astro:assets'
import Layout from '../../layouts/Layout.astro'
import { projects, type Project } from '../../data/projects'

export function getStaticPaths() {
  return projects
    .filter((p) => p.caseStudy)
    .map((project) => ({
      params: { slug: project.slug.replace('/case-study/', '') },
      props: { project },
    }))
}

const { project } = Astro.props as { project: Project }
const cs = project.caseStudy!

const currentIndex = projects.findIndex((p) => p.slug === project.slug)
const prevProject = currentIndex > 0 ? projects[currentIndex - 1] : null
const nextProject =
  currentIndex < projects.length - 1 ? projects[currentIndex + 1] : null
---

<Layout
  title={`${project.title} Case Study | Christopher Harley`}
  description={cs.subtitle}
  navVariant="case-study"
  footerVariant="case-study"
>
  <main class="grow">
    <!-- Hero Section -->
    <section class="max-w-max-width mx-auto px-edge-padding pt-24 pb-12">
      <div class="flex flex-col gap-6 mb-12">
        <h1 class="font-display-lg text-display-lg text-text-primary max-w-2xl">
          {project.title}
        </h1>
        <p
          class="font-body-md text-body-md text-text-secondary max-w-xl leading-relaxed"
        >
          <a
            class="font-semibold underline decoration-outline-variant underline-offset-4 hover:decoration-text-primary transition-all"
            href={cs.projectUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            {new URL(cs.projectUrl).hostname}
          </a>
          {cs.subtitle}
        </p>
      </div>

      <div
        class="w-full aspect-video bg-surface-container overflow-hidden rounded-lg border border-outline-variant"
      >
        <Image
          alt={cs.heroImageAlt}
          class="w-full h-full object-cover"
          src={cs.heroImage}
          width={1920}
          height={1080}
        />
      </div>
    </section>

    <!-- Project Metadata Grid -->
    <section class="max-w-max-width mx-auto px-edge-padding pb-12">
      <div class="border-t border-outline-variant pt-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
          <!-- Industry -->
          <div class="flex flex-col gap-1">
            <span
              class="font-label-mono text-label-mono uppercase tracking-wider text-text-secondary"
            >
              Industry
            </span>
            <p class="font-body-md text-body-md text-text-primary">
              {cs.industry}
            </p>
          </div>

          <!-- Category -->
          <div class="flex flex-col gap-1">
            <span
              class="font-label-mono text-label-mono uppercase tracking-wider text-text-secondary"
            >
              Category
            </span>
            {
              cs.category.map((cat) => (
                <div class="font-body-md text-body-md text-text-primary">
                  {cat}
                </div>
              ))
            }
          </div>

          <!-- Tech Stack -->
          <div class="flex flex-col gap-1">
            <span
              class="font-label-mono text-label-mono uppercase tracking-wider text-text-secondary"
            >
              Tech Stack
            </span>
            <ul class="flex flex-col gap-1">
              {
                cs.techStack.map((tech) => (
                  <li class="font-body-md text-body-md text-text-primary">
                    {tech}
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Live Site -->
          <div class="flex lg:justify-end items-start">
            <a
              class="inline-flex items-center gap-2 group hover:text-text-primary transition-colors text-text-primary font-bold"
              href={cs.liveLink}
              target="_blank"
            >
              <span
                class="font-label-mono text-label-mono uppercase tracking-widest"
              >
                Visit Live Site
              </span>
              <span
                class="material-symbols-outlined text-body-md transition-transform group-hover:translate-x-1"
              >
                arrow_outward
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Introduction Section (Dark) -->
    <section class="bg-text-primary text-white py-section-v-space">
      <div class="max-w-max-width mx-auto px-edge-padding">
        <div class="max-w-3xl flex flex-col gap-6">
          <span
            class="font-label-mono text-label-mono text-white/60 uppercase tracking-widest"
          >
            {cs.introduction.label}
          </span>
          <div class="flex flex-col gap-8">
            <h2
              class="font-display-lg text-display-lg italic leading-tight tracking-tight text-white"
            >
              {cs.introduction.heading}
            </h2>
            <p
              class="font-body-md text-body-md leading-relaxed text-white/80"
            >
              {cs.introduction.body}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- About The Design Section -->
    <section
      class="py-section-v-space px-edge-padding max-w-max-width mx-auto"
    >
      <div class="max-w-3xl flex flex-col gap-6 mb-12">
        <span
          class="font-label-mono text-label-mono text-text-secondary uppercase tracking-widest"
        >
          About the Design
        </span>
        <p
          class="font-body-md text-body-md text-text-secondary leading-relaxed"
        >
          {cs.design.description}
        </p>
      </div>

      <!-- Bento Grid Gallery (2x2) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
        {
          cs.design.images.map((img) => (
            <div class="bg-surface-container overflow-hidden rounded-lg border border-outline-variant">
              <Image
                alt={img.alt}
                class="w-full"
                src={img.src}
                width={Math.min(img.src.width, 1200)}
                height={Math.round(Math.min(img.src.width, 1200) * img.src.height / img.src.width)}
              />
            </div>
          ))
        }
      </div>
    </section>

    <!-- Development Section -->
    <section class="bg-surface-container-low py-section-v-space">
      <div class="max-w-max-width mx-auto px-edge-padding">
        <h2 class="font-headline-md text-headline-md text-text-primary mb-8">
          Development
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
          <div class="md:col-span-12">
            <p
              class="font-body-md text-body-md text-text-secondary leading-relaxed max-w-3xl"
            >
              {cs.development.body}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Conclusion Section -->
    <section
      class="py-section-v-space px-edge-padding max-w-max-width mx-auto text-center"
    >
      <div class="max-w-3xl mx-auto flex flex-col gap-6">
        <h2
          class="font-display-lg text-display-lg italic leading-tight text-text-primary"
        >
          {cs.conclusion.quote}
        </h2>
        <p
          class="font-body-md text-body-md text-text-secondary leading-relaxed"
        >
          {cs.conclusion.body}
        </p>
      </div>
    </section>

    <!-- Prev / Next Navigation -->
    <section class="max-w-max-width mx-auto px-edge-padding pb-16">
      <nav class="flex items-center gap-8 justify-center" aria-label="Project navigation">
        {
          prevProject ? (
            <a
              class="group flex items-center gap-2 text-text-secondary hover:text-text-primary transition-colors"
              href={prevProject.slug}
            >
              <span class="material-symbols-outlined text-body-md group-hover:-translate-x-0.5 transition-transform">
                west
              </span>
              <span class="font-label-mono text-label-mono uppercase tracking-widest">
                Prev Project
              </span>
            </a>
          ) : (
            <span class="flex items-center gap-2 text-text-secondary/30">
              <span class="material-symbols-outlined text-body-md">west</span>
              <span class="font-label-mono text-label-mono uppercase tracking-widest">
                Prev Project
              </span>
            </span>
          )
        }
        <div class="h-4 w-px bg-outline-variant" aria-hidden="true"></div>
        {
          nextProject ? (
            <a
              class="group flex items-center gap-2 text-text-secondary hover:text-text-primary transition-colors"
              href={nextProject.slug}
            >
              <span class="font-label-mono text-label-mono uppercase tracking-widest">
                Next Project
              </span>
              <span class="material-symbols-outlined text-body-md group-hover:translate-x-0.5 transition-transform">
                east
              </span>
            </a>
          ) : (
            <span class="flex items-center gap-2 text-text-secondary/30">
              <span class="font-label-mono text-label-mono uppercase tracking-widest">
                Next Project
              </span>
              <span class="material-symbols-outlined text-body-md">east</span>
            </span>
          )
        }
      </nav>
    </section>
  </main>
</Layout>

<script>
  const observerOptions = { threshold: 0.1 }
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('opacity-100', 'translate-y-0')
        entry.target.classList.remove('opacity-0', 'translate-y-4')
      }
    })
  }, observerOptions)

  document.querySelectorAll('section').forEach((section) => {
    if (!section.closest('nav, footer')) {
      section.classList.add(
        'transition-all',
        'duration-700',
        'ease-out',
        'opacity-0',
        'translate-y-4',
      )
      observer.observe(section)
    }
  })
</script>
