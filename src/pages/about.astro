---
export const prerender = true

import { Image } from 'astro:assets'
import Layout from '../layouts/Layout.astro'
import aboutImage from '../images/about-image.png'
---

<Layout
  title="About - Christopher Harley"
  description="About Christopher Harley, Design Engineer"
>
  <section
    class="max-w-max-width mx-auto px-edge-padding pb-section-v-space flex flex-col gap-section-v-space mb-section-v-space mt-section-v-space"
  >
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter items-start">
      <div class="md:col-span-5 relative w-full aspect-3/4 overflow-hidden">
        <Image
          src={aboutImage}
          alt="Christopher Harley Portrait"
          class="w-full h-full object-cover grayscale"
        />
      </div>
      <div class="md:col-span-7 flex flex-col pt-8 md:pt-0">
        <h1 class="font-headline-lg text-headline-lg text-text-primary mb-unit">
          Christopher Harley
        </h1>
        <div
          class="space-y-6 text-text-secondary font-body-lg text-body-lg max-w-prose mb-12"
        >
          <p>
            I’m Christopher Harley — a freelance web developer who builds clean,
            functional websites for small businesses and agencies. With six
            years of hands-on UX design and development, plus a software
            engineering role at a Fortune 500 company, I translate your vision
            into a site that looks great, works smoothly, and helps you connect
            with customers.
          </p>
          <p>
            My ten years of military service taught me discipline, clear
            communication, and a meticulous approach to planning — no surprises,
            just solid execution you can count on. Outside of work, I’m a
            drummer and electronic music producer, which keeps my design
            instincts sharp and creative. Whether you need a new site or a
            dependable partner for your agency’s next project, I’m ready to
            help. Let’s talk.
          </p>
        </div>
        <div
          class="flex flex-col sm:flex-row gap-6 items-start sm:items-center mt-auto border-t border-border-muted/30 pt-8"
        >
          <a
            href="/christopher_harley_resume.pdf"
            download
            class="inline-flex items-center justify-center px-6 py-3 border border-outline bg-transparent hover:bg-surface-container-low hover:border-text-primary transition-colors duration-200 text-text-primary"
          >
            <span class="font-label-mono text-label-mono mr-2"
              >Download Resume (PDF)</span
            >
            <span
              class="material-symbols-outlined"
              style="font-variation-settings: 'FILL' 0;">download</span
            >
          </a>
          <a
            href="/contact"
            class="font-label-mono text-label-mono text-text-primary hover:text-primary transition-colors duration-200 flex items-center gap-2"
          >
            Get in touch
            <span class="material-symbols-outlined text-[16px]"
              >arrow_forward</span
            >
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
