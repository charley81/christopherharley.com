---
import { Image } from 'astro:assets'
import type { Project } from '../data/projects'
export type { Project }
export interface Props {
  project: Project
}

const { project } = Astro.props
---

<a
  href={project.slug}
  class="block relative group cursor-pointer overflow-hidden aspect-video bg-surface-subtle border border-border-muted"
>
  <Image
    alt={project.imageAlt}
    class="w-full h-full object-cover"
    src={project.imageUrl}
    width={1920}
    height={1080}
  />
  <div
    class="absolute inset-0 bg-linear-to-t from-text-primary/90 via-text-primary/30 to-transparent flex flex-col justify-end p-gutter"
  >
    <h3 class="font-headline-md text-headline-md text-white mb-2">
      {project.title}
    </h3>
    <span
      class="text-white font-label-mono text-label-mono mb-4 flex items-center gap-2"
    >
      <span class="group-hover:underline">Read Case Study</span>
      <span
        class="material-symbols-outlined text-body-md group-hover:translate-x-1 transition-transform"
        >arrow_forward</span
      >
    </span>
    <div class="flex gap-2">
      {
        project.tags.map((tag) => (
          <span class="px-3 py-1 border border-white/30 rounded-full text-white text-[10px] uppercase font-label-mono">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</a>
