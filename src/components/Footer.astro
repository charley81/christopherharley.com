---
export interface Props {
  /** 'default' uses bg-background, 'case-study' uses bg-surface-container-low */
  variant?: 'default' | 'case-study'
}

const { variant = 'default' } = Astro.props
const bgClass =
  variant === 'case-study' ? 'bg-surface-container-low' : 'bg-background'
---

<footer
  class={`${bgClass} w-full py-unit border-t border-border-muted mt-auto`}
>
  <div
    class="flex flex-col md:flex-row justify-between items-center px-edge-padding max-w-max-width mx-auto gap-4"
  >
    <span class="font-label-mono text-[12px] text-text-secondary">
      @2026 Christopher Harley
    </span>
    <div class="flex gap-8">
      <a
        href="/about"
        class="font-caption text-[14px] text-text-secondary hover:text-text-primary transition-colors"
      >
        About
      </a>
      <a
        href="/contact"
        class="font-caption text-[14px] text-text-secondary hover:text-text-primary transition-colors"
      >
        Contact
      </a>
    </div>
  </div>
</footer>
